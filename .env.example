# Copy this file to ~/.config/automem/.env or export the values manually.
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=memories
# Qdrant connection: set QDRANT_URL (full URL) OR QDRANT_HOST + QDRANT_PORT.
# QDRANT_URL takes precedence when both are set.
QDRANT_API_KEY=
# Alternative to QDRANT_URL — set to internal hostname (e.g. qdrant.railway.internal).
# Constructs http://<QDRANT_HOST>:<QDRANT_PORT> automatically.
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_COLLECTION=memories
VECTOR_SIZE=1024  # Must match your embedding provider (1024=voyage-4, 3072=text-embedding-3-large, 768=text-embedding-3-small)
PORT=8001
OPENAI_API_KEY=
# For OpenAI-compatible providers (OpenRouter, LiteLLM, vLLM, etc.):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL=openai/text-embedding-3-small
# --- LLM classification (scripts/reclassify_with_llm.py) ---
# Optional. Defaults to OpenAI gpt-4o-mini via OPENAI_API_KEY.
# OPENROUTER_API_KEY=                    # used by --provider openrouter
# CLASSIFICATION_BASE_URL=               # any OpenAI-compatible endpoint
# CLASSIFICATION_API_KEY=                # key paired with CLASSIFICATION_BASE_URL
AUTOMEM_API_TOKEN=
ADMIN_API_TOKEN=
ENABLE_GRAPH_VIEWER=true
# Standalone public viewer service URL, e.g. https://automem-graph-viewer.up.railway.app.
# AutoMem keeps /viewer/* as the canonical entrypoint and forwards users here.
GRAPH_VIEWER_URL=
# Comma-separated public browser origins allowed to call the API.
# Set to the viewer domain in production, e.g. https://automem-graph-viewer.up.railway.app.
VIEWER_ALLOWED_ORIGINS=

# --- Consolidation tuning (optional) ---
# Defaults preserve existing behavior.
# CONSOLIDATION_CLUSTER_SIMILARITY_THRESHOLD=0.75
# CONSOLIDATION_MIN_CLUSTER_SIZE=3
# CONSOLIDATION_CLUSTER_INTERVAL_SECONDS=2592000

# --- Testing / CI (optional) ---
# Enable integration test suite (defaults to disabled)
# AUTOMEM_RUN_INTEGRATION_TESTS=1
# Start/stop Docker Compose automatically for integration tests
# AUTOMEM_START_DOCKER=1
# AUTOMEM_STOP_DOCKER=1
# Override API base URL for integration tests (default http://localhost:8001)
# AUTOMEM_TEST_BASE_URL=http://localhost:8001
# Allow tests to run against a non-local host (requires explicit opt-in)
# AUTOMEM_ALLOW_LIVE=0
# Tokens the integration tests will use when calling the API
# AUTOMEM_TEST_API_TOKEN=
# AUTOMEM_TEST_ADMIN_TOKEN=
